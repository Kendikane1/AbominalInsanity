    "    unseen_mask = np.isin(classes, list(unseen_labels_set))\n",
    "\n",
    "    norms_seen = weight_norms[seen_mask]\n",
    "    norms_unseen = weight_norms[unseen_mask]\n",
    "    biases_seen = intercept[seen_mask]\n",
    "    biases_unseen = intercept[unseen_mask]\n",
