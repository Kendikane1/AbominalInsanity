    "# =============================================================================\n",
    "# cWGAN-GP TRAINING\n",
    "# =============================================================================\n",
    "\n",
    "# Optimizers\n",
    "g_optimizer = torch.optim.Adam(\n",
    "    generator.parameters(),\n",
