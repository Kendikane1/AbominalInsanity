    "        self.ln1 = nn.LayerNorm(hidden_dims[0])\n",
    "        self.fc2 = nn.Linear(hidden_dims[0], hidden_dims[1])\n",
    "        self.ln2 = nn.LayerNorm(hidden_dims[1])\n",
